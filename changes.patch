class TestReadmeAccessibility:
    """Tests for accessibility considerations."""
    
    @pytest.fixture(scope="class")
    def readme_content(self):
        """Load README.md content."""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_emojis_not_overused(self, readme_content):
        """Verify emojis enhance but don't overwhelm content."""
        emoji_count = len(re.findall(r'[\U0001F600-\U0001F64F\U0001F300-\U0001F5FF\U0001F680-\U0001F6FF\U0001F1E0-\U0001F1FF\U00002702-\U000027B0\U000024C2-\U0001F251]', readme_content))
        assert emoji_count > 10, "Should have emojis for modern look"
        assert emoji_count < 100, "Should not be overwhelmed with emojis"
    
    def test_headings_hierarchy(self, readme_content):
        """Verify heading hierarchy is correct (no skipping levels)."""
        lines = readme_content.split('\n')
        prev_level = 0
        for line in lines:
            if line.startswith('#'):
                level = len(line) - len(line.lstrip('#'))
                if prev_level > 0:
                    assert level <= prev_level + 1, f"Heading level jumped: {line}"
                prev_level = level


