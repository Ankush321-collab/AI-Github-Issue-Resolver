class TestReadmeLinks:
    """Tests for validating links in README."""
    
    @pytest.fixture(scope="class")
    def readme_content(self):
        """Load README.md content."""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_anchor_links_valid(self, readme_content):
        """Verify anchor links reference existing sections."""
        # Extract all anchor links
        links = re.findall(r'\]\(#[^)]+\)', readme_content)
        headers = re.findall(r'^#{1,6}\s+.+$', readme_content, re.MULTILINE)
        
        # Convert headers to anchor format (lowercase, spaces to hyphens, remove punctuation)
        header_anchors = set()
        for header in headers:
            anchor = header.lower().replace(' ', '-').replace('#', '').strip()
            anchor = re.sub(r'[^\w\-]', '', anchor)
            header_anchors.add(anchor)
        
        # Check each link
        for link in links:
            anchor = link[2:-1].lower().replace('-', '')
            # Simple check - anchor should match some header
            assert len(anchor) > 0, f"Empty anchor found: {link}"
    
    def test_external_links_https(self, readme_content):
        """Verify external links use HTTPS."""
        http_links = re.findall(r'http://[^\s\)]+', readme_content)
        # Allow localhost and specific exceptions
        non_local_http = [link for link in http_links if 'localhost' not in link]
        assert len(non_local_http) == 0, f"Found HTTP links (should be HTTPS): {non_local_http}"
    
    def test_github_links_valid(self, readme_content):
        """Verify GitHub repository links are correct."""
        assert "https://github.com/Ankush321-collab/AI-Github-Issue-Resolver" in readme_content, \
            "Should have correct repo URL"


class TestReadmeImages:
    """Tests for image references."""
    
    @pytest.fixture(scope="class")
    def readme_content(self):
        """Load README.md content."""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_images_have_alt_text(self, readme_content):
        """Verify all images have alt text."""
        # Find markdown images ![alt](url)
        images = re.findall(r'!\[([^\]]*)\]\(([^)]+)\)', readme_content)
        for alt, url in images:
            assert len(alt) > 0, f"Image missing alt text: {url}"
    
    def test_architecture_image_exists(self, readme_content):
        """Verify architecture diagram is referenced."""
        assert "diagram-export" in readme_content or "architecture" in readme_content.lower(), \
            "Should reference architecture diagram"
    
    def test_badges_loadable(self, readme_content):
        """Verify badge URLs are from reliable sources."""
        badge_urls = re.findall(r'https://img\.shields\.io/[^\s\)]+', readme_content)
        assert len(badge_urls) > 0, "Should have shields.io badges"
        for url in badge_urls:
            assert url.startswith("https://"), "Badge URLs should be HTTPS"


